# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://127.0.0.1:3002

# Spotify API Configuration
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3002/callback

# Official catalog packs (optional — server reads LK-owned playlists for hosts)
# TEMPO_CATALOG_SPOTIFY_REFRESH_TOKEN=...
# TEMPO_CATALOG_PLAYLIST_NAME_PREFIX=GoT
# If host OAuth uses encrypted org credentials but catalog refresh fails with invalid_client, either set
# SPOTIFY_CLIENT_SECRET to match your Dashboard app, or reuse org credentials:
# TEMPO_CATALOG_SPOTIFY_CREDENTIALS_USER_ID=1
# Or override only the secret used for catalog refresh (client id still from row / env):
# TEMPO_CATALOG_SPOTIFY_CLIENT_SECRET=...
